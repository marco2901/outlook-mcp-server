# =============================================================================
# Microsoft Azure App Registration
# Azure Portal > App Registrations > Your App
# =============================================================================

# Application (client) ID
MS_CLIENT_ID=your-client-id-here

# Client secret VALUE (not the secret ID) — Certificates & secrets
MS_CLIENT_SECRET=your-client-secret-here

# Directory (tenant) ID — use a tenant GUID for single-tenant apps,
# "common" for multi-tenant.
MS_TENANT_ID=your-tenant-id-here

# Optional: override the Microsoft authority host (e.g. for sovereign clouds)
# MS_AUTHORITY_HOST=https://login.microsoftonline.com

# Optional: override OAuth scopes (space-separated). Default covers Mail/Calendar/OneDrive/Contacts.
# MS_SCOPES=offline_access User.Read Mail.Read Mail.Send Calendars.ReadWrite Files.ReadWrite Contacts.Read

# =============================================================================
# Public OAuth callback URL
# In a Traefik-fronted deployment this should be the HTTPS host that resolves
# to the container, e.g. https://outlook-mcp.example.com
# Used to derive the redirect URI: {OAUTH_PUBLIC_BASE_URL}/auth/callback
# This URL must be registered as a redirect URI in your Azure app.
# =============================================================================
OAUTH_PUBLIC_BASE_URL=https://outlook-mcp.example.com

# Or override the redirect URI explicitly (defaults to OAUTH_PUBLIC_BASE_URL/auth/callback)
# MS_REDIRECT_URI=https://outlook-mcp.example.com/auth/callback

# =============================================================================
# Token persistence
# Default for local stdio: ~/.outlook-mcp-tokens.json
# In Docker we use /data/outlook-mcp-tokens.json on a mounted volume.
# =============================================================================
# TOKEN_STORE_PATH=/data/outlook-mcp-tokens.json

# =============================================================================
# Traefik
# =============================================================================
MCP_DOMAIN=outlook-mcp.example.com

# =============================================================================
# MCP gateway auth (any of these protects /mcp, /sse, /messages)
# =============================================================================
# Static bearer token for tools/CLI access
MCP_API_KEY=your-secret-api-key

# Authelia OIDC introspection (für Claude.ai OAuth)
OIDC_CLIENT_ID=outlook-mcp
OIDC_CLIENT_SECRET=your-oidc-secret
# Public Authelia URL (Issuer) — used for OAuth Protected Resource Metadata
OIDC_ISSUER_URL=https://authelia.example.com

# =============================================================================
# Misc
# =============================================================================
# Set to true to use mock data instead of real Graph API calls
USE_TEST_MODE=false
