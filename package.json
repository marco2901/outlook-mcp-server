{
  "name": "outlook-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for Microsoft 365 (Outlook, OneDrive, Power Automate) via Microsoft Graph API. Forked from ryaker/outlook-mcp with HTTP transport, MCP auth gateway and OAuth callback integrated.",
  "main": "index.js",
  "bin": {
    "outlook-mcp": "./index.js",
    "outlook-mcp-auth": "./outlook-auth-server.js"
  },
  "scripts": {
    "start": "node index.js",
    "start:http": "node index.js --http --port 3000",
    "auth-server": "node outlook-auth-server.js",
    "test-mode": "USE_TEST_MODE=true node index.js",
    "inspect": "npx @modelcontextprotocol/inspector node index.js",
    "test": "jest"
  },
  "keywords": [
    "claude",
    "outlook",
    "onedrive",
    "power-automate",
    "microsoft-365",
    "mcp",
    "microsoft-graph",
    "email"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.5.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.10.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
